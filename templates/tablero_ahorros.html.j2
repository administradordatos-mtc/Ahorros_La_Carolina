<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Tablero Único de Propuestas de Ahorro</title>
  <style>
    :root { --bg:#f5f7fb; --card:#fff; --text:#172033; --muted:#687083; --blue:#1d4ed8; --green:#047857; --red:#b91c1c; --amber:#b45309; --line:#d9dfeb; }
    * { box-sizing: border-box; }
    body { margin:0; font-family: Arial, Helvetica, sans-serif; color:var(--text); background:var(--bg); }
    header { padding: 28px 32px; background: linear-gradient(135deg, #0f172a, #1d4ed8); color:white; }
    header h1 { margin:0 0 8px; font-size: 28px; }
    header p { margin:0; opacity:.9; }
    main { padding: 24px 32px 48px; }
    .kpis { display:grid; grid-template-columns: repeat(auto-fit, minmax(210px,1fr)); gap:16px; margin-bottom:22px; }
    .card { background:var(--card); border:1px solid var(--line); border-radius:16px; padding:18px; box-shadow:0 8px 24px rgba(15,23,42,.06); }
    .card .label { color:var(--muted); font-size:13px; margin-bottom:8px; }
    .card .value { font-size:25px; font-weight:700; }
    .green { color:var(--green); } .red { color:var(--red); } .amber { color:var(--amber); } .blue { color:var(--blue); }
    section { margin-top:22px; }
    h2 { font-size:20px; margin:0 0 14px; }
    .filters { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap:12px; align-items:end; }
    label { font-size:13px; color:var(--muted); display:block; margin-bottom:5px; }
    select, button { width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:10px; background:white; }
    button { background:var(--blue); color:white; border:0; cursor:pointer; font-weight:700; }
    button.secondary { background:#334155; }
    .table-wrap { overflow:auto; border:1px solid var(--line); border-radius:14px; background:white; }
    table { width:100%; border-collapse: collapse; min-width: 1100px; }
    th, td { border-bottom:1px solid var(--line); padding:10px 12px; text-align:left; vertical-align:top; font-size:14px; }
    th { background:#f8fafc; color:#334155; position:sticky; top:0; z-index:1; }
    tr.row-blocked { background:#fff1f2; }
    .badge { display:inline-block; border-radius:999px; padding:4px 8px; font-size:12px; font-weight:700; }
    .badge-blocked { background:#fee2e2; color:var(--red); }
    .badge-ok { background:#dcfce7; color:var(--green); }
    .badge-warn { background:#fef3c7; color:var(--amber); margin-left:4px; }
    .muted { color:var(--muted); }
    .summary-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(230px,1fr)); gap:14px; }
    .dept-card h3 { margin:0 0 10px; }
    .dept-card p { margin:6px 0; }
    footer { margin-top:28px; color:var(--muted); font-size:12px; }
    @media (max-width: 720px) { header, main { padding-left:16px; padding-right:16px; } }
  </style>
</head>
<body>
<header>
  <h1>Tablero Único de Propuestas de Ahorro</h1>
  <p>Seguimiento por departamento, responsable, estado, evidencia, cálculo, ahorro estimado, ahorro real y bloqueos.</p>
</header>
<main>
  <div class="kpis">
    <div class="card"><div class="label">Total propuestas</div><div class="value blue">{{ kpis.total_propuestas }}</div></div>
    <div class="card"><div class="label">Ahorro estimado total</div><div class="value green">{{ fmt(kpis.ahorro_estimado_total) }}</div></div>
    <div class="card"><div class="label">Ahorro real total</div><div class="value green">{{ fmt(kpis.ahorro_real_total) }}</div></div>
    <div class="card"><div class="label">Diferencia estimado vs real</div><div class="value amber">{{ fmt(kpis.diferencia_ahorro) }}</div></div>
    <div class="card"><div class="label">Propuestas bloqueadas</div><div class="value red">{{ kpis.propuestas_bloqueadas }}</div></div>
    <div class="card"><div class="label">Implementadas o medidas</div><div class="value green">{{ kpis.propuestas_implementadas }}</div></div>
    <div class="card"><div class="label">Pendientes evidencia</div><div class="value amber">{{ kpis.propuestas_pendientes_evidencia }}</div></div>
    <div class="card"><div class="label">Pendientes cálculo</div><div class="value amber">{{ kpis.propuestas_pendientes_calculo }}</div></div>
  </div>

  <section class="card">
    <h2>Filtros</h2>
    <div class="filters">
      <div><label>Departamento</label><select id="filterDepartamento"><option value="">Todos</option>{% for item in departamentos %}<option>{{ item }}</option>{% endfor %}</select></div>
      <div><label>Responsable</label><select id="filterResponsable"><option value="">Todos</option>{% for item in responsables %}<option>{{ item }}</option>{% endfor %}</select></div>
      <div><label>Estado</label><select id="filterEstado"><option value="">Todos</option>{% for item in estados %}<option>{{ item }}</option>{% endfor %}</select></div>
      <div><label>Bloqueo</label><select id="filterBloqueo"><option value="">Todas</option><option value="si">Bloqueadas</option><option value="no">No bloqueadas</option></select></div>
      <div><label>&nbsp;</label><button onclick="exportFilteredCSV()">Exportar CSV filtrado</button></div>
      <div><label>&nbsp;</label><button class="secondary" onclick="resetFilters()">Limpiar filtros</button></div>
    </div>
  </section>

  <section>
    <h2>Resumen por departamento</h2>
    <div class="summary-grid">
      {% for dept in department_summary %}
      <div class="card dept-card">
        <h3>{{ dept.departamento }}</h3>
        <p><strong>Propuestas:</strong> {{ dept.propuestas }}</p>
        <p><strong>Ahorro estimado:</strong> {{ fmt(dept.ahorro_estimado) }}</p>
        <p><strong>Ahorro real:</strong> {{ fmt(dept.ahorro_real) }}</p>
        <p><strong>Bloqueos:</strong> <span class="{{ 'red' if dept.bloqueos else 'green' }}">{{ dept.bloqueos }}</span></p>
      </div>
      {% endfor %}
    </div>
  </section>

  <section>
    <h2>Detalle de propuestas</h2>
    <div class="table-wrap">
      <table id="proposalsTable">
        <thead>
          <tr>
            <th>Departamento</th><th>Propuesta</th><th>Responsable</th><th>Cifra estimada</th><th>Cálculo</th><th>Evidencia</th><th>Fecha implementación</th><th>Estado</th><th>Ahorro real</th><th>Bloqueo</th>
          </tr>
        </thead>
        <tbody>
        {% for row in proposals %}
          <tr class="{{ 'row-blocked' if row.esta_bloqueada else '' }}" data-departamento="{{ row.departamento }}" data-responsable="{{ row.responsable }}" data-estado="{{ row.estado }}" data-bloqueada="{{ 'si' if row.esta_bloqueada else 'no' }}">
            <td>{{ row.departamento }}</td>
            <td>{{ row.propuesta }}</td>
            <td>{{ row.responsable }}</td>
            <td>{{ fmt(row.cifra_estimada) }}</td>
            <td>{{ row.calculo or '<span class="badge badge-warn">Pendiente cálculo</span>'|safe }}</td>
            <td>{{ row.evidencia or '<span class="badge badge-warn">Pendiente evidencia</span>'|safe }}</td>
            <td>{{ row.fecha_implementacion or '<span class="muted">Sin fecha</span>'|safe }}</td>
            <td><span class="badge {{ 'badge-blocked' if row.esta_bloqueada else 'badge-ok' }}">{{ row.estado }}</span></td>
            <td>{{ fmt(row.ahorro_real) }}</td>
            <td>{{ row.bloqueo or '<span class="muted">Sin bloqueo</span>'|safe }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <footer>Generado localmente desde <code>data/propuestas_ahorro.csv</code>.</footer>
</main>
<script>
const filters = ['filterDepartamento','filterResponsable','filterEstado','filterBloqueo'];
filters.forEach(id => document.getElementById(id).addEventListener('change', applyFilters));
function applyFilters(){
  const dep = document.getElementById('filterDepartamento').value;
  const resp = document.getElementById('filterResponsable').value;
  const estado = document.getElementById('filterEstado').value;
  const bloqueo = document.getElementById('filterBloqueo').value;
  document.querySelectorAll('#proposalsTable tbody tr').forEach(row => {
    const show = (!dep || row.dataset.departamento === dep) && (!resp || row.dataset.responsable === resp) && (!estado || row.dataset.estado === estado) && (!bloqueo || row.dataset.bloqueada === bloqueo);
    row.style.display = show ? '' : 'none';
  });
}
function resetFilters(){ filters.forEach(id => document.getElementById(id).value = ''); applyFilters(); }
function exportFilteredCSV(){
  const rows = Array.from(document.querySelectorAll('#proposalsTable tr'));
  const visible = rows.filter((row, idx) => idx === 0 || row.style.display !== 'none');
  const csv = visible.map(row => Array.from(row.children).map(cell => '"' + cell.innerText.replaceAll('"','""').replaceAll('\n',' ') + '"').join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = 'propuestas_ahorro_filtradas.csv'; a.click(); URL.revokeObjectURL(url);
}
</script>
</body>
</html>
