<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>La Carolina | Tablero de Ahorros</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --carolina-red:#b5121b; --carolina-red-dark:#7f0d14; --carolina-gold:#d6a33a; --carolina-black:#111111;
      --bg:#fff8ef; --surface:#ffffff; --surface-warm:#fff2dc; --text:#18120f; --muted:#6f6258; --line:#ead7bd;
      --green:#18794e; --red:#b5121b; --amber:#a66a00; --blue:#2454a6; --shadow:0 18px 48px rgba(80, 30, 15, .12);
    }
    * { box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { margin:0; font-family:'IBM Plex Sans', system-ui, -apple-system, 'Segoe UI', sans-serif; color:var(--text); background:linear-gradient(180deg,#fff8ef 0%,#fff 42%,#fff8ef 100%); }
    .topbar { background:var(--carolina-black); color:#fff; border-bottom:4px solid var(--carolina-gold); }
    .topbar-inner { max-width:1440px; margin:0 auto; padding:16px 32px; display:flex; align-items:center; justify-content:space-between; gap:18px; }
    .brand { display:flex; align-items:center; gap:14px; min-width:0; }
    .brand-logo { width:58px; height:58px; object-fit:cover; border-radius:50%; border:2px solid var(--carolina-gold); background:white; }
    .brand-title { line-height:1.1; }
    .brand-title strong { display:block; font-size:20px; letter-spacing:.2px; }
    .brand-title span { display:block; color:#f9df9f; font-size:13px; font-weight:600; letter-spacing:.28px; text-transform:uppercase; margin-top:4px; }
    .top-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; justify-content:flex-end; }
    .pill { border:1px solid rgba(255,255,255,.22); color:#fff; padding:8px 12px; border-radius:999px; font-size:12px; background:rgba(255,255,255,.06); }
    .hero { background:radial-gradient(circle at 10% 0%, rgba(214,163,58,.32), transparent 32%), linear-gradient(135deg,var(--carolina-red-dark),var(--carolina-red) 52%,#2b0a0d); color:white; }
    .hero-inner { max-width:1440px; margin:0 auto; padding:40px 32px 34px; display:grid; grid-template-columns:minmax(0,1.5fr) minmax(280px,.8fr); gap:24px; align-items:end; }
    .eyebrow { display:inline-flex; align-items:center; gap:8px; color:#ffe9ad; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; margin-bottom:14px; }
    .eyebrow::before { content:""; width:28px; height:3px; background:var(--carolina-gold); display:inline-block; }
    h1 { margin:0; font-size:clamp(34px,5vw,60px); line-height:1.02; font-weight:300; letter-spacing:-1.2px; }
    .hero p { max-width:820px; margin:18px 0 0; color:#fff5df; font-size:17px; line-height:1.55; }
    .hero-panel { background:rgba(17,17,17,.34); border:1px solid rgba(255,255,255,.18); border-radius:22px; padding:22px; backdrop-filter: blur(8px); }
    .hero-panel .label { color:#ffe9ad; font-size:12px; text-transform:uppercase; letter-spacing:.8px; font-weight:700; }
    .hero-panel .amount { font-size:34px; font-weight:700; margin-top:6px; color:#fff; }
    .hero-panel .note { color:#f8e7ce; font-size:13px; margin-top:8px; }
    main { max-width:1440px; margin:0 auto; padding:26px 32px 56px; }
    .kpis { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:16px; margin-top:-48px; position:relative; z-index:2; }
    .card { background:var(--surface); border:1px solid var(--line); border-radius:22px; padding:18px; box-shadow:var(--shadow); }
    .kpi-card { position:relative; overflow:hidden; min-height:132px; }
    .kpi-card::after { content:""; position:absolute; inset:auto -36px -46px auto; width:112px; height:112px; border-radius:50%; background:rgba(214,163,58,.18); }
    .kpi-card.priority { background:linear-gradient(135deg,#111,#3a0b0f); color:white; border-color:#3a0b0f; }
    .kpi-card.priority .label, .kpi-card.priority .helper { color:#f2d998; }
    .label { color:var(--muted); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; margin-bottom:8px; }
    .value { font-size:clamp(24px,3vw,34px); font-weight:700; letter-spacing:-.5px; }
    .helper { color:var(--muted); font-size:12px; margin-top:8px; line-height:1.35; }
    .green { color:var(--green); } .red { color:var(--red); } .amber { color:var(--amber); } .blue { color:var(--blue); } .gold { color:var(--carolina-gold); }
    .section-title { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin:30px 0 14px; }
    .section-title h2 { font-size:24px; font-weight:600; margin:0; letter-spacing:-.2px; }
    .section-title p { margin:0; color:var(--muted); font-size:14px; }
    .filters-card { background:linear-gradient(180deg,#fff,#fff6e6); }
    .filters { display:grid; grid-template-columns:1.2fr repeat(4, minmax(150px, .8fr)) auto auto; gap:12px; align-items:end; }
    label { font-size:12px; color:var(--muted); display:block; margin-bottom:6px; font-weight:700; text-transform:uppercase; letter-spacing:.45px; }
    select, input, button { width:100%; height:44px; padding:10px 12px; border:1px solid var(--line); border-radius:14px; background:white; color:var(--text); font:inherit; }
    input:focus, select:focus, button:focus { outline:3px solid rgba(214,163,58,.32); border-color:var(--carolina-gold); }
    button { background:var(--carolina-red); color:white; border-color:var(--carolina-red); cursor:pointer; font-weight:700; white-space:nowrap; transition:.18s ease; }
    button:hover { background:var(--carolina-red-dark); transform:translateY(-1px); }
    button.secondary { background:#1f1f1f; border-color:#1f1f1f; }
    .filter-status { margin-top:12px; display:flex; gap:10px; flex-wrap:wrap; align-items:center; color:var(--muted); font-size:13px; }
    .status-dot { width:9px; height:9px; border-radius:50%; background:var(--green); display:inline-block; }
    .summary-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:14px; }
    .dept-card { box-shadow:none; border-radius:18px; background:#fff; position:relative; overflow:hidden; }
    .dept-card::before { content:""; position:absolute; left:0; top:0; bottom:0; width:6px; background:linear-gradient(180deg,var(--carolina-red),var(--carolina-gold)); }
    .dept-card h3 { margin:0 0 12px 8px; font-size:18px; }
    .dept-card p { margin:7px 0 7px 8px; color:var(--muted); }
    .dept-card strong { color:var(--text); }
    .bar { height:8px; border-radius:999px; background:#f4e5cd; overflow:hidden; margin:12px 0 0 8px; }
    .bar span { display:block; height:100%; border-radius:999px; background:linear-gradient(90deg,var(--carolina-red),var(--carolina-gold)); width:var(--w); }
    .table-card { padding:0; overflow:hidden; }
    .table-header { padding:18px; display:flex; justify-content:space-between; gap:12px; align-items:center; border-bottom:1px solid var(--line); background:#fffaf0; }
    .table-header h2 { margin:0; font-size:22px; }
    .table-wrap { overflow:auto; background:white; max-height:680px; }
    table { width:100%; border-collapse:collapse; min-width:1240px; }
    th, td { border-bottom:1px solid #f0dfc8; padding:12px 14px; text-align:left; vertical-align:top; font-size:14px; }
    th { background:#191919; color:#fff; position:sticky; top:0; z-index:1; font-size:12px; text-transform:uppercase; letter-spacing:.45px; }
    tbody tr:nth-child(even) { background:#fffaf2; }
    tbody tr:hover { background:#fff1d6; }
    tr.row-blocked { background:#fff0f1 !important; }
    .proposal { font-weight:600; color:#25130f; }
    .money { font-family:'IBM Plex Mono', ui-monospace, monospace; font-weight:600; white-space:nowrap; }
    .badge { display:inline-flex; align-items:center; gap:6px; border-radius:999px; padding:5px 9px; font-size:12px; font-weight:700; white-space:nowrap; }
    .badge-blocked { background:#ffe1e4; color:var(--carolina-red-dark); }
    .badge-ok { background:#e4f7ec; color:var(--green); }
    .badge-warn { background:#fff0c7; color:var(--amber); }
    .badge-neutral { background:#ececec; color:#333; }
    .muted { color:var(--muted); }
    .empty-state { display:none; padding:34px; text-align:center; color:var(--muted); }
    footer { margin-top:28px; padding:18px 0; color:var(--muted); font-size:12px; display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; border-top:1px solid var(--line); }
    @media (max-width:1180px) { .kpis { grid-template-columns:repeat(2,minmax(0,1fr)); } .filters { grid-template-columns:repeat(2,minmax(0,1fr)); } .hero-inner { grid-template-columns:1fr; } }
    @media (max-width:720px) { .topbar-inner, .hero-inner, main { padding-left:16px; padding-right:16px; } .brand-logo { width:48px; height:48px; } .kpis { grid-template-columns:1fr; margin-top:-28px; } .filters { grid-template-columns:1fr; } .top-actions { justify-content:flex-start; } }
    @media print { .filters-card, .top-actions, button { display:none !important; } body { background:white; } .card { box-shadow:none; } .kpis { margin-top:0; } }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <img class="brand-logo" src="{{ logo_src }}" alt="Logo La Carolina">
        <div class="brand-title"><strong>La Carolina</strong><span>Transporte con Corazón</span></div>
      </div>
      <div class="top-actions">
        <span class="pill">Tablero ejecutivo</span>
        <span class="pill">Fuente: propuestas_ahorro.csv</span>
        <span class="pill">Generado: {{ generated_at }}</span>
      </div>
    </div>
  </div>
  <header class="hero">
    <div class="hero-inner">
      <div>
        <div class="eyebrow">Ahorros La Carolina</div>
        <h1>Tablero único de propuestas de ahorro</h1>
        <p>Seguimiento corporativo por departamento con estimación, ahorro real, evidencia, cálculo, fecha de implementación, estado y bloqueos para priorizar decisiones.</p>
      </div>
      <div class="hero-panel">
        <div class="label">Potencial estimado</div>
        <div class="amount">{{ fmt(kpis.ahorro_estimado_total) }}</div>
        <div class="note">Ahorro real medido: <strong>{{ fmt(kpis.ahorro_real_total) }}</strong>. Brecha pendiente: <strong>{{ fmt(kpis.diferencia_ahorro) }}</strong>.</div>
      </div>
    </div>
  </header>

  <main>
    <div class="kpis">
      <div class="card kpi-card priority"><div class="label">Ahorro estimado total</div><div class="value gold">{{ fmt(kpis.ahorro_estimado_total) }}</div><div class="helper">Valor proyectado de todas las iniciativas.</div></div>
      <div class="card kpi-card"><div class="label">Ahorro real total</div><div class="value green">{{ fmt(kpis.ahorro_real_total) }}</div><div class="helper">Ahorro ya implementado o medido.</div></div>
      <div class="card kpi-card"><div class="label">Total propuestas</div><div class="value blue">{{ kpis.total_propuestas }}</div><div class="helper">Iniciativas registradas en el archivo fuente.</div></div>
      <div class="card kpi-card"><div class="label">Bloqueos activos</div><div class="value red">{{ kpis.propuestas_bloqueadas }}</div><div class="helper">Requieren gestión para liberar ahorro.</div></div>
      <div class="card kpi-card"><div class="label">Implementadas o medidas</div><div class="value green">{{ kpis.propuestas_implementadas }}</div><div class="helper">Iniciativas con avance material.</div></div>
      <div class="card kpi-card"><div class="label">Pendientes evidencia</div><div class="value amber">{{ kpis.propuestas_pendientes_evidencia }}</div><div class="helper">Necesitan soporte documental.</div></div>
      <div class="card kpi-card"><div class="label">Pendientes cálculo</div><div class="value amber">{{ kpis.propuestas_pendientes_calculo }}</div><div class="helper">Necesitan fórmula o soporte del cálculo.</div></div>
      <div class="card kpi-card"><div class="label">Brecha estimado vs real</div><div class="value amber">{{ fmt(kpis.diferencia_ahorro) }}</div><div class="helper">Potencial todavía no capturado.</div></div>
    </div>

    <section class="card filters-card">
      <div class="section-title"><div><h2>Explorar propuestas</h2><p>Filtra, busca y exporta el detalle visible.</p></div></div>
      <div class="filters">
        <div><label>Búsqueda rápida</label><input id="searchText" type="search" placeholder="Buscar propuesta, responsable, cálculo o evidencia"></div>
        <div><label>Departamento</label><select id="filterDepartamento"><option value="">Todos</option>{% for item in departamentos %}<option>{{ item }}</option>{% endfor %}</select></div>
        <div><label>Responsable</label><select id="filterResponsable"><option value="">Todos</option>{% for item in responsables %}<option>{{ item }}</option>{% endfor %}</select></div>
        <div><label>Estado</label><select id="filterEstado"><option value="">Todos</option>{% for item in estados %}<option>{{ item }}</option>{% endfor %}</select></div>
        <div><label>Bloqueo</label><select id="filterBloqueo"><option value="">Todas</option><option value="si">Bloqueadas</option><option value="no">No bloqueadas</option></select></div>
        <div><label>&nbsp;</label><button onclick="exportFilteredCSV()">Exportar CSV</button></div>
        <div><label>&nbsp;</label><button class="secondary" onclick="resetFilters()">Limpiar</button></div>
      </div>
      <div class="filter-status"><span class="status-dot"></span><span id="visibleCount">{{ kpis.total_propuestas }}</span> de <span>{{ kpis.total_propuestas }}</span> propuestas visibles</div>
    </section>

    <div class="section-title"><div><h2>Resumen por departamento</h2><p>Ranking por ahorro estimado y control de bloqueos.</p></div></div>
    <section class="summary-grid">
      {% for dept in department_summary %}
      <div class="card dept-card">
        <h3>{{ dept.departamento }}</h3>
        <p><strong>Propuestas:</strong> {{ dept.propuestas }}</p>
        <p><strong>Ahorro estimado:</strong> {{ fmt(dept.ahorro_estimado) }}</p>
        <p><strong>Ahorro real:</strong> {{ fmt(dept.ahorro_real) }}</p>
        <p><strong>Bloqueos:</strong> <span class="{{ 'red' if dept.bloqueos else 'green' }}">{{ dept.bloqueos }}</span></p>
        <div class="bar" aria-label="Participación estimada"><span style="--w:{{ dept.participacion }}%"></span></div>
      </div>
      {% endfor %}
    </section>

    <section class="card table-card">
      <div class="table-header"><div><h2>Detalle de propuestas</h2><p class="muted">Encabezado fijo, filas alternas y alertas visuales para seguimiento operativo.</p></div><button class="secondary" onclick="window.print()">Imprimir / PDF</button></div>
      <div class="table-wrap">
        <table id="proposalsTable">
          <thead><tr><th>Departamento</th><th>Propuesta</th><th>Responsable</th><th>Cifra estimada</th><th>Cálculo</th><th>Evidencia</th><th>Fecha implementación</th><th>Estado</th><th>Ahorro real</th><th>Bloqueo</th></tr></thead>
          <tbody>
          {% for row in proposals %}
            <tr class="{{ 'row-blocked' if row.esta_bloqueada else '' }}" data-departamento="{{ row.departamento }}" data-responsable="{{ row.responsable }}" data-estado="{{ row.estado }}" data-bloqueada="{{ 'si' if row.esta_bloqueada else 'no' }}" data-search="{{ (row.departamento ~ ' ' ~ row.propuesta ~ ' ' ~ row.responsable ~ ' ' ~ row.calculo ~ ' ' ~ row.evidencia ~ ' ' ~ row.estado ~ ' ' ~ row.bloqueo)|lower }}">
              <td>{{ row.departamento }}</td>
              <td class="proposal">{{ row.propuesta }}</td>
              <td>{{ row.responsable }}</td>
              <td class="money">{{ fmt(row.cifra_estimada) }}</td>
              <td>{{ row.calculo or '<span class="badge badge-warn">Pendiente cálculo</span>'|safe }}</td>
              <td>{{ row.evidencia or '<span class="badge badge-warn">Pendiente evidencia</span>'|safe }}</td>
              <td>{{ row.fecha_implementacion or '<span class="muted">Sin fecha</span>'|safe }}</td>
              <td><span class="badge {{ 'badge-blocked' if row.esta_bloqueada else ('badge-ok' if row.implementada_o_medida else 'badge-neutral') }}">{{ row.estado }}</span></td>
              <td class="money">{{ fmt(row.ahorro_real) }}</td>
              <td>{{ row.bloqueo or '<span class="muted">Sin bloqueo</span>'|safe }}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
        <div id="emptyState" class="empty-state">No hay propuestas que coincidan con los filtros seleccionados.</div>
      </div>
    </section>

    <footer><span>La Carolina · Transporte con Corazón</span><span>Archivo fuente: <code>data/propuestas_ahorro.csv</code></span></footer>
  </main>
<script>
const filterIds = ['searchText','filterDepartamento','filterResponsable','filterEstado','filterBloqueo'];
filterIds.forEach(id => document.getElementById(id).addEventListener(id === 'searchText' ? 'input' : 'change', applyFilters));
function norm(v){ return (v || '').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,''); }
function applyFilters(){
  const dep = document.getElementById('filterDepartamento').value;
  const resp = document.getElementById('filterResponsable').value;
  const estado = document.getElementById('filterEstado').value;
  const bloqueo = document.getElementById('filterBloqueo').value;
  const q = norm(document.getElementById('searchText').value);
  let visible = 0;
  document.querySelectorAll('#proposalsTable tbody tr').forEach(row => {
    const searchOk = !q || norm(row.dataset.search).includes(q);
    const show = searchOk && (!dep || row.dataset.departamento === dep) && (!resp || row.dataset.responsable === resp) && (!estado || row.dataset.estado === estado) && (!bloqueo || row.dataset.bloqueada === bloqueo);
    row.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  document.getElementById('visibleCount').textContent = visible;
  document.getElementById('emptyState').style.display = visible ? 'none' : 'block';
}
function resetFilters(){ filterIds.forEach(id => document.getElementById(id).value = ''); applyFilters(); }
function exportFilteredCSV(){
  const rows = Array.from(document.querySelectorAll('#proposalsTable tr'));
  const visible = rows.filter((row, idx) => idx === 0 || row.style.display !== 'none');
  const csv = visible.map(row => Array.from(row.children).map(cell => '"' + cell.innerText.replaceAll('"','""').replaceAll('\n',' ') + '"').join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = 'propuestas_ahorro_filtradas.csv'; a.click(); URL.revokeObjectURL(url);
}
applyFilters();
</script>
</body>
</html>
